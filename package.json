{
  "name": "openflipbook",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source clone of flipbook.page — image-is-the-UI, BYO-keys demo.",
  "license": "MIT",
  "author": "Eren Akbulut <erenakbulutwork@gmail.com>",
  "homepage": "https://github.com/eren23/openflipbook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eren23/openflipbook.git"
  },
  "bugs": {
    "url": "https://github.com/eren23/openflipbook/issues"
  },
  "keywords": [
    "flipbook",
    "image-as-ui",
    "nano-banana",
    "ltx-video",
    "openrouter",
    "modal",
    "nextjs"
  ],
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @openflipbook/web dev",
    "build": "pnpm --filter @openflipbook/web build",
    "start": "pnpm --filter @openflipbook/web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "backend": "cd apps/modal-backend && PORT=8787 .venv/bin/python local_server.py",
    "modal:serve": "cd apps/modal-backend && modal serve generate.py ltx_stream.py",
    "modal:deploy": "cd apps/modal-backend && modal deploy generate.py ltx_stream.py",
    "record-demo": "cd scripts/record-demo && pnpm install --ignore-workspace --silent && pnpm start"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "typescript-eslint": "^8.16.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix --max-warnings=20",
    "apps/modal-backend/**/*.py": "bash -lc 'cd apps/modal-backend && .venv/bin/ruff check --fix'"
  }
}
